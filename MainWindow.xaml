<Window x:Class="RblxExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Syntax Executor" Height="570" Width="920"
        Background="Transparent" Foreground="#D1D5DB"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Inter, sans-serif">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#050507"/>
        <SolidColorBrush x:Key="BgPanel" Color="#0B0B0F"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#08080A"/>
        <SolidColorBrush x:Key="CardBg" Color="#0F0F15"/>
        <SolidColorBrush x:Key="CardHover" Color="#161620"/>
        <SolidColorBrush x:Key="SilverText" Color="#666666"/>
        <SolidColorBrush x:Key="SilverLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00FF88"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#00A2FF"/>
        <SolidColorBrush x:Key="AccentDanger" Color="#FF4B4B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#1E1E26"/>
        
        <DropShadowEffect x:Key="NeonGlow" BlurRadius="15" Color="#00FF88" Opacity="0.5" ShadowDepth="0"/>

        <Style x:Key="MyScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="#3F3F4E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5B5B6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MyScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTab" TargetType="RadioButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555566"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="indicator" Width="3" Height="20" Background="#00FF88" CornerRadius="0,2,2,0" HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="#00FF88" Opacity="0.7" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="10" Margin="8,0,8,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#888899"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="#00FF88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SilverText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.08" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.08" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Foreground" Value="#00FF88"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource NeonGlow}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScriptCard" TargetType="Border">
            <Setter Property="Background" Value="#0A0A0E"/>
            <Setter Property="BorderBrush" Value="#1E1E26"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16,18"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#00FF88"/>
                    <Setter Property="Background" Value="#12121A"/>
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="ClientCard" TargetType="Border" BasedOn="{StaticResource ScriptCard}">
            <Setter Property="Padding" Value="25"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="{StaticResource BgMain}" CornerRadius="12" ClipToBounds="False" MouseLeftButtonDown="TitleBar_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="5" Opacity="0.5" Direction="270"/>
        </Border.Effect>
        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0" Panel.ZIndex="10">
                    <Button Content="—" Foreground="{StaticResource SilverText}" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="Minimize_Click" Cursor="Hand" FontSize="14" ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#222"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="✕" Foreground="{StaticResource SilverText}" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="Close_Click" Cursor="Hand" FontSize="14" Margin="4,0,0,0" ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" Padding="0,30,0,0">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <RadioButton Style="{StaticResource SidebarTab}" IsChecked="True" Checked="Tab_Editor" ToolTip="Editor">
                                    <Path Data="M 4,16 L 12,8 L 4,0 M 14,16 L 20,16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                                </RadioButton>
                                <RadioButton Style="{StaticResource SidebarTab}" Checked="Tab_ScriptHub" ToolTip="Script Hub">
                                    <Path Data="M 2,4 L 14,4 M 2,8 L 14,8 M 2,12 L 14,12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                </RadioButton>
                                <RadioButton Style="{StaticResource SidebarTab}" Checked="Tab_Clients" ToolTip="Clients">
                                    <Path Data="M 8,8 A 4,4 0 1,0 8,0 A 4,4 0 1,0 8,8 Z M 0,16 C 0,10 16,10 16,16" Fill="Transparent" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18" StrokeEndLineCap="Round"/>
                                </RadioButton>
                            </StackPanel>

                            <RadioButton Style="{StaticResource SidebarTab}" Margin="0,0,0,25" VerticalAlignment="Bottom" Checked="Tab_Settings" ToolTip="Settings">
                                <Path Data="M 2,4 L 14,4 M 2,8 L 14,8 M 2,12 L 14,12 M 4,2 L 4,6 M 12,6 L 12,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                            </RadioButton>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="ViewEditor" Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <Grid Margin="25,0">
                                    <TextBlock Text="S Y N T A X" FontWeight="Black" FontSize="15" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,85,0">
                                        <Button Style="{StaticResource PlayBtn}" Click="Execute_Click" ToolTip="Execute Script">
                                            <Path Data="M 2,0 L 12,7 L 2,14 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="12" Height="14"/>
                                        </Button>
                                        <Button Style="{StaticResource IconBtn}" Margin="5,0" Click="Clear_Click" ToolTip="Clear Editor">
                                            <Path Data="M 2,14 L 6,14 L 14,6 L 10,2 L 2,10 Z M 10,2 L 14,6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="14" Height="14" StrokeLineJoin="Round" StrokeEndLineCap="Round"/>
                                        </Button>

                                        <Border Width="1" Height="18" Background="#333340" Margin="10,0"/>

                                        <Button Style="{StaticResource IconBtn}" Margin="0,0,5,0" Click="Save_Click" ToolTip="Save File">
                                            <Path Data="M 2,2 L 14,2 L 14,14 L 2,14 Z M 5,2 L 5,6 L 11,6 L 11,2 M 4,14 L 4,9 L 12,9 L 12,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" StrokeLineJoin="Round"/>
                                        </Button>
                                        <Button Style="{StaticResource IconBtn}" Click="Open_Click" ToolTip="Open File">
                                            <Path Data="M 1,4 L 6,4 L 8,6 L 15,6 L 15,13 L 1,13 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="16" Height="12" StrokeLineJoin="Round"/>
                                        </Button>

                                        <Border Width="1" Height="18" Background="#333340" Margin="10,0"/>
                                        <Button Style="{StaticResource IconBtn}" Click="KillRoblox_Click" ToolTip="Kill Process">
                                            <Path Data="M 2,2 L 14,14 M 14,2 L 2,14" Stroke="{StaticResource AccentDanger}" StrokeThickness="2" Stretch="Uniform" Width="12" Height="12" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource BgMain}">
                                <avalonEdit:TextEditor Name="Editor" 
                                                       FontFamily="Consolas, 'Courier New', monospace" FontSize="14"
                                                       Background="Transparent" Foreground="{StaticResource SilverLight}"
                                                       ShowLineNumbers="True" LineNumbersForeground="#3A3A4A" Margin="0" Padding="6,10,10,10">
                                </avalonEdit:TextEditor>
                            </Border>
                        </Grid>

                        <Grid x:Name="ViewScriptHub" Grid.Row="0" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="Script Hub" Foreground="White" FontSize="26" FontWeight="Black" Margin="35,35,35,15"/>

                                    <ItemsControl x:Name="ScriptHubList" Margin="25,10">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ScriptCard}">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Path Data="M 2,2 L 10,2 L 14,6 L 14,14 L 2,14 Z M 10,2 L 10,6 L 14,6" Stroke="{StaticResource AccentBlue}" StrokeThickness="1.5" Stretch="Uniform" Width="16" Height="20" Margin="0,0,15,0" StrokeLineJoin="Round"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource SilverLight}" FontSize="15" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Style="{StaticResource PlayBtn}" Click="ExecuteScriptHub_Click" Tag="{Binding FullPath}">
                                                                <Path Data="M 2,0 L 12,7 L 2,14 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="11" Height="14"/>
                                                            </Button>
                                                            <Button Style="{StaticResource IconBtn}" Click="CopyScriptHub_Click" Tag="{Binding FullPath}">
                                                                <Path Data="M 4,4 L 10,4 L 10,12 L 4,12 Z M 6,2 L 12,2 L 12,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="14" StrokeLineJoin="Round"/>
                                                            </Button>
                                                            <Button Style="{StaticResource IconBtn}" Click="DeleteScriptHub_Click" Tag="{Binding FullPath}">
                                                                <Path Data="M 3,4 L 13,4 M 6,4 L 6,2 L 10,2 L 10,4 M 4,4 L 4,14 L 12,14 L 12,4" Stroke="{StaticResource AccentDanger}" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="14" StrokeLineJoin="Round"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="ViewClients" Grid.Row="0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Active Clients" Foreground="White" FontSize="26" FontWeight="Black" Margin="35,35,35,15"/>

                                <Grid Margin="35,0">
                                    <Border Style="{StaticResource ClientCard}" Width="280" HorizontalAlignment="Left">
                                        <StackPanel>
                                            <Border Width="75" Height="75" CornerRadius="37.5" Background="#22222E" Margin="0,0,0,20" ClipToBounds="True" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                <Image x:Name="ClientAvatarImage" Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <DrawingImage>
                                                            <DrawingImage.Drawing>
                                                                <GeometryDrawing Brush="Transparent">
                                                                    <GeometryDrawing.Pen>
                                                                        <Pen Brush="{StaticResource AccentBlue}" Thickness="2" EndLineCap="Round" StartLineCap="Round" LineJoin="Round"/>
                                                                    </GeometryDrawing.Pen>
                                                                    <GeometryDrawing.Geometry>
                                                                        <GeometryGroup>
                                                                            <PathGeometry Figures="M 8,8 A 4,4 0 1,0 8,0 A 4,4 0 1,0 8,8 Z M 0,16 C 0,10 16,10 16,16"/>
                                                                        </GeometryGroup>
                                                                    </GeometryDrawing.Geometry>
                                                                </GeometryDrawing>
                                                            </DrawingImage.Drawing>
                                                        </DrawingImage>
                                                    </Image.Source>
                                                </Image>
                                            </Border>
                                            <TextBlock x:Name="ClientAccountName" Text="LocalPlayer" TextAlignment="Center" FontSize="20" Foreground="{StaticResource SilverLight}" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="ClientPidText" Text="PID: None • Place: Unknown" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SilverText}" Margin="0,0,0,20"/>

                                            <Border Name="ClientBadgeBg" Background="#111116" BorderThickness="1" BorderBrush="#2A2A35" CornerRadius="20" Padding="15,6" HorizontalAlignment="Center">
                                                <TextBlock x:Name="ClientStatusBadge" Text="NOT ATTACHED" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SilverText}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="ViewSettings" Grid.Row="0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Configuration" Foreground="White" FontSize="26" FontWeight="Black" Margin="35,35,35,15"/>

                                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="12" Margin="35,5,35,0" Padding="25">
                                    <StackPanel>
                                        <TextBlock Text="Developer Controls" Foreground="{StaticResource SilverLight}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,18"/>

                                        <CheckBox IsChecked="False" Checked="ToggleConsole_Checked" Unchecked="ToggleConsole_Unchecked" Cursor="Hand">
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border x:Name="track" Width="40" Height="22" CornerRadius="11" Background="#1A1A24" BorderBrush="#2A2A35" BorderThickness="1">
                                                            <Border x:Name="thumb" Width="16" Height="16" CornerRadius="8" Background="#555566" HorizontalAlignment="Left" Margin="2,0,0,0" VerticalAlignment="Center">
                                                                <Border.RenderTransform>
                                                                    <TranslateTransform X="0"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                        </Border>
                                                        <TextBlock Text="Debug Console" Foreground="{StaticResource SilverText}" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="track" Property="Background" Value="#0D3322"/>
                                                            <Setter TargetName="track" Property="BorderBrush" Value="#00FF88"/>
                                                            <Setter TargetName="thumb" Property="Background" Value="#00FF88"/>
                                                            <Setter TargetName="thumb" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <TranslateTransform X="18"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter TargetName="thumb" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="6" Color="#00FF88" Opacity="0.6" ShadowDepth="0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="track" Property="BorderBrush" Value="#3A3A45"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Background="#08080C" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#00FF88" Offset="0"/>
                                                <GradientStop Color="#00CC66" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="6" Color="#00FF88" Opacity="0.8" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="InjectionStatus" Text="Idle" Foreground="#555566" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource PlayBtn}" Click="Attach_Click" ToolTip="Attach to Roblox">
                                    <Path Data="M 10,2 L 10,6 L 14,6 L 14,10 M 6,14 L 6,10 L 2,10 L 2,6 M 10,6 L 6,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Stretch="Uniform" Width="16" Height="16" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                                </Button>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Canvas HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,25,50" Panel.ZIndex="100">
                    <Border x:Name="NotificationBox" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1" CornerRadius="10" Padding="20,15" MinWidth="220" Visibility="Collapsed" Canvas.Bottom="0" Canvas.Right="0">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="NotificationIcon" Data="M 8,2 A 6,6 0 1 1 7.9,2.1 Z M 6,8 L 8,10 L 12,5" Stroke="{StaticResource AccentGreen}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18" Margin="0,0,15,0" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                            <TextBlock x:Name="NotificationText" Text="Notification" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>
        </Border>
    </Border>
</Window>